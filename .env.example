# API app configuration example
ASPNETCORE_ENVIRONMENT=Development
Azure__TenantId=00000000-0000-0000-0000-000000000000

DocumentIntelligence__Endpoint=https://your-document-intelligence-resource.cognitiveservices.azure.com/
DocumentIntelligence__ApiKey=
DocumentIntelligence__ExtractionMethod=document_intelligence

AzureOpenAI__Endpoint=https://your-openai-resource.openai.azure.com/
AzureOpenAI__DeploymentName=gpt-4o
AzureOpenAI__ApiKey=

# Optional for local development. Leave blank to disable search integration.
Search__Endpoint=
Search__ApiKey=
Search__IndexName=court-documents
Search__EmbeddingDeploymentName=text-embedding-3-small
Search__OpenAIEndpoint=https://your-openai-resource.openai.azure.com/

Storage__LocalStoragePath=./documents
Storage__MaxUploadBytes=20971520

Workflow__ConfidenceThreshold=0.7
Resilience__MaxRetries=3
Resilience__BaseDelayMs=250
Resilience__MaxDelayMs=2000
Resilience__OperationTimeoutSeconds=90
