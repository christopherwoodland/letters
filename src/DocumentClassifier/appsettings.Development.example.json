{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Azure": {
    "TenantId": "00000000-0000-0000-0000-000000000000"
  },
  "DocumentIntelligence": {
    "Endpoint": "https://your-document-intelligence-resource.cognitiveservices.azure.com/",
    "ApiKey": "",
    "ExtractionMethod": "document_intelligence",
    "MinLocalExtractionChars": 50
  },
  "AzureOpenAI": {
    "Endpoint": "https://your-openai-resource.openai.azure.com/",
    "DeploymentName": "gpt-4o",
    "ApiKey": ""
  },
  "Storage": {
    "LocalStoragePath": "./documents",
    "MaxUploadBytes": 20971520
  },
  "Search": {
    "Endpoint": "",
    "ApiKey": "",
    "IndexName": "court-documents",
    "EmbeddingDeploymentName": "text-embedding-3-small",
    "OpenAIEndpoint": "https://your-openai-resource.openai.azure.com/"
  },
  "Workflow": {
    "ConfidenceThreshold": 0.7,
    "EnableRagExamples": false,
    "EnableRagIndexing": false,
    "EnableRagQuery": false
  },
  "Resilience": {
    "MaxRetries": 3,
    "BaseDelayMs": 250,
    "MaxDelayMs": 2000,
    "OperationTimeoutSeconds": 90
  }
