# Auto detect text files and normalize line endings to LF
# https://help.github.com/articles/dealing-with-line-endings/

# Auto detect
* text=auto

# C#/ASP.NET
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.xaml text eol=lf
*.ashx text eol=lf
*.asax text eol=lf
*.aspx text eol=lf

# JavaScript/TypeScript/JSX/TSX
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Web assets
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.ps1 text eol=lf

# Markdown/Documentation
*.md text eol=lf
*.markdown text eol=lf
*.txt text eol=lf

# YAML/TOML
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Configuration files
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.dockerignore text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf
docker-compose.yaml text eol=lf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gif binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
*.sqlite binary

# Archives
*.zip binary
*.tar binary
*.tgz binary
*.rar binary
*.7z binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
